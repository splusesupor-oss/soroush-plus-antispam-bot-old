# فایل نمونه - آن را کپی کنید به .env و مقادیر را پر کنید
# cp .env.example .env

# ========= حالت یوزر-بات (پیشنهادی برای مدیریت گروه) =========
# SESSION_STRING را بعد از اولین اجرای main.py دریافت می‌کنید
SOROUSH_SESSION_STRING=
# اگر کلید API شخصی دارید (اختیاری، SPlusthon کلید پیش‌فرض دارد)
API_ID=
API_HASH=

# ========= حالت ربات رسمی (جایگزین) =========
# توکن ربات که از @MrBot در سروش پلاس می‌گیرید
BOT_TOKEN=
SOROUSH_BOT_TOKEN=

# ========= تنظیمات اضافی =========
# آیدی گروه‌های هدف (اختیاری، خالی = همه گروه‌ها)
# TARGET_GROUPS=-100123456789,-100987654321
